SELECT CUSTOMER.NAME,
       PRODUCT.DESCRIPTION
  FROM CUSTOMER
       INNER JOIN
       CUSTOMER_ORDER ON CUSTOMER.CUSTOMER_ID = CUSTOMER_ORDER.CUSTOMER_ID
       INNER JOIN
       PRODUCT ON PRODUCT.PRODUCT_ID = CUSTOMER_ORDER.PRODUCT_ID;

SELECT CUSTOMER.NAME,
       CUSTOMER_ORDER.SHIP_DATE
  FROM CUSTOMER
       INNER JOIN
       CUSTOMER_ORDER ON CUSTOMER.CUSTOMER_ID = CUSTOMER_ORDER.CUSTOMER_ID
 WHERE CUSTOMER.REGION = 'Southwest';

SELECT CUSTOMER_ORDER.ORDER_ID,
       CUSTOMER.NAME,
       (CUSTOMER_ORDER.ORDER_QTY * PRODUCT.PRICE) AS VALOR_TOTAL
  FROM CUSTOMER
       INNER JOIN
       CUSTOMER_ORDER ON CUSTOMER.CUSTOMER_ID = CUSTOMER_ORDER.CUSTOMER_ID
       INNER JOIN
       PRODUCT ON PRODUCT.PRODUCT_ID = CUSTOMER_ORDER.PRODUCT_ID;

SELECT CUSTOMER.NAME
  FROM CUSTOMER
       INNER JOIN
       CUSTOMER_ORDER ON CUSTOMER_ORDER.CUSTOMER_ID = CUSTOMER.CUSTOMER_ID;