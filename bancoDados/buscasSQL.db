SELECT * FROM PRODUCT;
SELECT PRICE, DESCRIPTION FROM PRODUCT;
SELECT * FROM PRODUCT WHERE PRICE > 10;
SELECT DESCRIPTION FROM PRODUCT WHERE PRICE BETWEEN 5 AND 10;
SELECT PRICE, DESCRIPTION FROM PRODUCT WHERE DESCRIPTION LIKE "S%";
SELECT * FROM PRODUCT WHERE PRICE ORDER BY PRICE;
SELECT DESCRIPTION FROM PRODUCT WHERE PRICE < 20  ORDER BY DESCRIPTION;
SELECT * FROM CUSTOMER WHERE REGION = "Southwest";
SELECT NAME, CITY FROM CUSTOMER WHERE STATE = "TX";
SELECT * FROM CUSTOMER WHERE STATE IN ("TX", "OK");
SELECT * FROM CUSTOMER WHERE NAME LIKE ("%Construction%");
SELECT * FROM CUSTOMER WHERE NOT REGION = "Southwest";
SELECT * FROM CUSTOMER WHERE CITY = 'Irving' AND STATE = 'TX';
SELECT * FROM CUSTOMER LIMIT 3;
SELECT * FROM CUSTOMER_ORDER WHERE SHIPPED = 'false';
SELECT ORDER_ID, ORDER_QTY FROM CUSTOMER_ORDER WHERE ORDER_QTY >= 100;
SELECT * FROM CUSTOMER_ORDER WHERE ORDER_DATE >= '2015-05-18';
SELECT ORDER_ID, ORDER_QTY FROM CUSTOMER_ORDER WHERE ORDER_QTY BETWEEN 350 AND 550;
SELECT * FROM CUSTOMER_ORDER WHERE CUSTOMER_ID = 1;
SELECT * FROM CUSTOMER_ORDER WHERE PRODUCT_ID = 2  AND ORDER_QTY > 200 ORDER BY ORDER_DATE;